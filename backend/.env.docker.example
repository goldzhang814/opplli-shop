# App
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_NAME=MyStore
APP_URL=http://localhost:9010
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://93.127.134.171:3000,http://93.127.134.171:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Database (host machine)
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=ecom_db
MYSQL_USER=ecom_user
MYSQL_PASSWORD=ecom_pass
MYSQL_ROOT_PASSWORD=root_pass
DATABASE_URL=mysql+aiomysql://root:ofidc.com@host.docker.internal:3306/ecom_db

# Redis (host machine)
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@host.docker.internal:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/facebook/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM string, newlines as \n
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/apple/callback

# ── Payment — Stripe ────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Payment — PayPal ────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox# sandbox | live
PAYPAL_WEBHOOK_ID=

# ── Payment — Airwallex ─────────────────────────────────────────────
AIRWALLEX_CLIENT_ID=DUXWVpblTKSTcOJlQsYE9Q
AIRWALLEX_API_KEY=a54958b1dcdc253a863423c5cb2e841a44fce60aa9b8b75335e5971159906329877dd3827ad05a70da7fe435bd0b74a2
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_ENV=demo# demo | prod

# Email
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=MyStore
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Media Storage
STORAGE_BACKEND=local
MEDIA_LOCAL_PATH=/app/media
MEDIA_URL_PREFIX=/media

# Super Admin (seeded via migration)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# Celery (if you run workers separately)
CELERY_BROKER_URL=redis://:redis_pass@host.docker.internal:6379/1
CELERY_RESULT_BACKEND=redis://:redis_pass@host.docker.internal:6379/2
