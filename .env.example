# ── App ────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_NAME=My Store
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ────────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=ecom_db
MYSQL_USER=ecom_user
MYSQL_PASSWORD=ecom_pass
MYSQL_ROOT_PASSWORD=root_pass
DATABASE_URL=mysql+aiomysql://ecom_user:ecom_pass@mysql:3306/ecom_db

# ── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@redis:6379/0

# ── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/facebook/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=       # PEM string, newlines as \n
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/apple/callback

# ── Payment — Stripe ────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Payment — PayPal ────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox          # sandbox | live
PAYPAL_WEBHOOK_ID=

# ── Payment — Airwallex ─────────────────────────────────────────────
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_ENV=demo           # demo | prod

# ── Email ───────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend        # resend | sendgrid | smtp
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=My Store
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Media Storage ───────────────────────────────────────────────────
STORAGE_BACKEND=local        # local | s3
MEDIA_LOCAL_PATH=/app/media
MEDIA_URL_PREFIX=/media      # URL prefix for local files

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
CLOUDFLARE_CDN_URL=https://cdn.example.com   # CDN prefix for S3 files

# ── Super Admin (seeded via migration) ─────────────────────────────
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# ── Celery ──────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_pass@redis:6379/2
