FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .

ARG NUXT_PUBLIC_API_BASE=/api
ARG NUXT_PUBLIC_SITE_URL=https://www.opplii.com
ARG NUXT_PUBLIC_STRIPE_KEY=
ARG NUXT_PUBLIC_AIRWALLEX_KEY=
ARG NUXT_PUBLIC_AIRWALLEX_ENV=production

ENV NUXT_PUBLIC_API_BASE=$NUXT_PUBLIC_API_BASE
ENV NUXT_PUBLIC_SITE_URL=$NUXT_PUBLIC_SITE_URL
ENV NUXT_PUBLIC_STRIPE_KEY=$NUXT_PUBLIC_STRIPE_KEY
ENV NUXT_PUBLIC_AIRWALLEX_KEY=$NUXT_PUBLIC_AIRWALLEX_KEY
ENV NUXT_PUBLIC_AIRWALLEX_ENV=$NUXT_PUBLIC_AIRWALLEX_ENV

RUN npm run build

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/.output /app/.output
ENV NODE_ENV=production
ENV PORT=3000
EXPOSE 3000
CMD ["node", ".output/server/index.mjs"]